# ---- Required for production ----
ADMIN_API_KEY=          # API key for admin endpoints (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
AGENT_SECRET=           # Shared secret for campus agent WebSocket connection
WHATSAPP_WEBHOOK_VERIFY_TOKEN=  # Token for Meta Cloud API webhook verification

# ---- Environment mode ----
ENVIRONMENT=production  # Set to "development" to disable auth requirements

# ---- CORS ----
CORS_ALLOWED_ORIGINS=   # Comma-separated origins, e.g. https://your-dashboard.com,http://localhost:3000

# ---- Green API (WhatsApp) ----
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_URL=https://7107.api.greenapi.com
GREEN_API_WEBHOOK_TOKEN=  # Optional: if set, webhook verifies Bearer token instead of IP allowlist

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- Meta Cloud API (optional, if using Meta instead of Green API) ----
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
